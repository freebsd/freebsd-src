; config options
CONFIG_END
SCENARIO_BEGIN Test AXFR and IXFR queries.

; AXFR
STEP 1 QUERY
ENTRY_BEGIN
SECTION QUESTION
nlnetlabs.nl. IN AXFR
ENTRY_END
STEP 2 CHECK_ANSWER
ENTRY_BEGIN
MATCH all
REPLY QR REFUSED
SECTION QUESTION
nlnetlabs.nl. IN AXFR
ENTRY_END

; IXFR
STEP 3 QUERY
ENTRY_BEGIN
SECTION QUESTION
nlnetlabs.nl. IN IXFR
SECTION AUTHORITY
nlnetlabs.nl. IN SOA mr. op. 12 0 0 0 0
ENTRY_END
STEP 4 CHECK_ANSWER
ENTRY_BEGIN
MATCH all
REPLY QR FORMERR
; The SOA RR should not be echoed back.
; The question section is absent, because it gives a formerr because of the
; authority section contents.
;SECTION QUESTION
;nlnetlabs.nl. IN IXFR
ENTRY_END

SCENARIO_END
