#!/bin/sh
#
#

# PROVIDE: ddb
# REQUIRE: dumpon
# BEFORE: disks
# KEYWORD: nojail

. /etc/rc.subr

name="ddb"
desc="DDB kernel debugger"
rcvar="ddb_enable"
command="/sbin/${name}"
start_precmd="ddb_prestart"
start_cmd="ddb_start"
stop_cmd=":"

ddb_prestart()
{
	# Silently exit if ddb is not enabled
	if ! ${SYSCTL_N} -q debug.ddb.scripting.script >/dev/null; then
		exit 1
	fi
}

ddb_start()
{
	${command} ${command_args}
}

load_rc_config $name

required_files="${ddb_config}"
command_args="${ddb_config}"

# doesn't make sense to run in a svcj: privileged operation
ddb_svcj="NO"

run_rc_command "$1"
